# ---- Schwab Trader API ----
# From your app at developer.schwab.com
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here
# Must EXACTLY match the callback registered on your Schwab app
SCHWAB_CALLBACK_URL=https://127.0.0.1/
# Where the OAuth token is cached (gitignored). Refresh is handled automatically.
SCHWAB_TOKEN_PATH=token.json

# ---- Database ----
# Matches docker-compose.yml (host port 5433 to avoid colliding with other Postgres)
DATABASE_URL=postgresql+psycopg://schwab:schwab_local_dev@localhost:5433/schwab_trader

# ---- App ----
# Comma-separated tickers to stream on startup (Phase 1 demo)
WATCHLIST=RCAT,SYM,IREN,RKLB,QBTS
